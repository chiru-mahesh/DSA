class node:
    def __init__(self, data):
        self.data=data
        self.next=None
head=None
def insertbegin(data):
    global head
    newnode= node(data)
    newnode.next= head
    head= newnode

n=int(input("enter number of nodes:"))
for _ in range(n):
    val= int(input("enter the value"))
    insertbegin(val)
temp=head
while temp:
    print(temp.data,end= "->")
    temp=temp.next
print("Node")